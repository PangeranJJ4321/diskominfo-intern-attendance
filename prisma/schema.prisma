// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../app/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions        Session[]
  accounts        Account[]
  faceDescriptors FaceDescriptor[]
  interns         Intern[] // One user can have multiple internship histories across different agencies
  agencyAccesses  AgencyAccess[] // Granular access control for managing agencies

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AgencyAccess {
  id        String   @id @default(cuid())
  agencyId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([userId])
  @@map("agency_access")
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  interns   Intern[]

  @@map("institution")
}

model Agency {
  id             String   @id @default(cuid())
  name           String
  defaultShiftId String? // The fallback shift assigned automatically to new interns
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  interns        Intern[]
  agencyAccesses AgencyAccess[]
  shifts         Shift[]
  holidays       AgencyHoliday[]
  agencyArea     AgencyArea?
  rule           AgencyRule?
  defaultShift   Shift?          @relation("DefaultShift", fields: [defaultShiftId], references: [id], onDelete: SetNull)

  @@index([defaultShiftId])
  @@map("agency")
}

model Intern {
  id            String    @id @default(cuid())
  userId        String
  agencyId      String
  institutionId String?
  startedAt     DateTime
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution      Institution?      @relation(fields: [institutionId], references: [id])
  agency           Agency            @relation(fields: [agencyId], references: [id])
  attendances      Attendance[]
  shiftAssignments ShiftAssignment[] // Scheduling tied directly to the intern profile
  locationLogs     LocationLog[] // Fraud logs tracked per specific internship instance

  @@index([userId])
  @@index([agencyId])
  @@map("intern")
}

model Shift {
  id             String    @id @default(cuid())
  agencyId       String // Scopes shifts securely to each specific agency
  name           String // e.g., "Security 1 (Day)", "IT Support Shift"
  workOnHolidays Boolean   @default(false)
  deletedAt      DateTime? // Soft delete support

  agency          Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  schedules       Schedule[]
  assignments     ShiftAssignment[]
  defaultAgencies Agency[]          @relation("DefaultShift")

  @@index([agencyId])
  @@map("shift")
}

model Schedule {
  id            String    @id @default(cuid())
  shiftId       String
  name          String // e.g., "Morning Check-in", "Afternoon Checkout"
  dayOfWeek     Int // 0 = Sunday, 1 = Monday, ... 6 = Saturday
  windowStart   String // "07:00:00" -> Earliest check-in window opening
  scheduleStart String // "08:00:00" -> Official start time
  lateCutoff    String // "08:15:00" -> LATE status boundary (replaces agency-wide late threshold)
  scheduleEnd   String // "09:00:00" -> Window closure
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete support

  shift       Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@index([shiftId])
  @@map("schedule")
}

model ShiftAssignment {
  id        String  @id @default(cuid())
  internId  String // Shift assignment tied directly to Intern
  shiftId   String
  startDate String // YYYY-MM-DD format
  endDate   String? // YYYY-MM-DD format (Null means active indefinitely)

  intern Intern @relation(fields: [internId], references: [id], onDelete: Cascade)
  shift  Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([internId, startDate, endDate, shiftId])
  @@map("shift_assignment")
}

model AgencyHoliday {
  id          String   @id @default(cuid())
  agencyId    String
  date        String // YYYY-MM-DD format
  description String // e.g., "Hari Kemerdekaan RI"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("agency_holiday")
}

model AgencyArea {
  id        String   @id @default(cuid())
  agencyId  String   @unique // Strict 1:1 rule pairing agency to its active geofence
  geoData   Json // Leaflet-compatible GeoJSON boundaries
  timezone  String   @default("Asia/Makassar")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("agency_area")
}

model AgencyRule {
  id                      String   @id @default(cuid())
  agencyId                String   @unique
  requireFaceVerification Boolean  @default(true)
  requireWithinArea       Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("agency_rule")
}

model FaceDescriptor {
  id         String   @id @default(cuid())
  userId     String // Stays on User level because a person's biometric identity is persistent across multiple internships
  descriptor Json // 68-point face descriptors array
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("face_descriptor")
}

model Attendance {
  id         String @id @default(cuid())
  internId   String // Tied directly to Intern instead of User
  scheduleId String // Fulfills a specific schedule slot
  date       String // YYYY-MM-DD string format

  attendanceTime           DateTime?
  attendanceLatitude       Float?
  attendanceLongitude      Float?
  attendancePhotoUrl       String? // Visual verification support
  attendanceFaceDescriptor Json? // Snapshot array used during execution validation

  status AttendanceStatus @default(ABSENT)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  intern   Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([internId, scheduleId, date])
  @@index([internId])
  @@index([scheduleId])
  @@index([date])
  @@map("attendance")
}

model LocationLog {
  id        String   @id @default(cuid())
  internId  String // Log stream tied explicitly to an internship context
  latitude  Float
  longitude Float
  ipAddress String? // VPN and network spoof tracking configuration
  createdAt DateTime @default(now())

  intern Intern @relation(fields: [internId], references: [id], onDelete: Cascade)

  @@index([internId])
  @@index([createdAt])
  @@map("location_log")
}

enum AttendanceStatus {
  PRESENT
  LATE
  SICK
  EXCUSED
  ABSENT
}
